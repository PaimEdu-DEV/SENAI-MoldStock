rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminDoc() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isAdmin() && adminDoc().data.role == 'superadmin';
    }

    match /pecas/{pecaId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /ocorrencias/{ocorrenciaId} {
      allow read, create, update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow create: if (
        signedIn()
        && request.auth.uid == adminId
        && request.resource.data.email.matches('.*@docente\\.senai\\.br$')
        && request.resource.data.role == 'admin'
      ) || (
        isSuperAdmin()
        && request.resource.data.role in ['admin', 'superadmin']
      );
      allow update, delete: if isSuperAdmin();
    }
  }
}
