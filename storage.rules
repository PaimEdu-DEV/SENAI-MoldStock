rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null;
    }

    match /pecas/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /documents/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
